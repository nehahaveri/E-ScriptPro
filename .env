# Google OAuth Configuration
# Add your Google OAuth credentials here
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here

SPRING_PROFILES_ACTIVE=docker
SPRING_CLOUD_GATEWAY_ROUTES[0]_ID=auth-service
SPRING_CLOUD_GATEWAY_ROUTES[0]_URI=http://authservice:8080
SPRING_CLOUD_GATEWAY_ROUTES[0]_PREDICATES[0]=Path=/api/auth/**
SPRING_CLOUD_GATEWAY_ROUTES[0]_FILTERS[0]=StripPrefix=1
